<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
  <meta name="format-detection" content="telephone=no">
  <title>ж•°еӯҰиЁҳеҸ· Unicode еӨүжҸӣгғ„гғјгғ«</title>
  <style>
    :root {
      --bg: #f5f7fb;
      --panel: #ffffff;
      --text: #1f2937;
      --muted: #667085;
      --border: #d8dee9;
      --accent: #2563eb;
      --accent-hover: #1d4ed8;
      --code: #eef2ff;
      --shadow: rgba(0, 0, 0, 0.07);
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111827;
        --panel: #1f2937;
        --text: #f3f4f6;
        --muted: #a9b2c3;
        --border: #445066;
        --accent: #3b82f6;
        --accent-hover: #60a5fa;
        --code: #283548;
        --shadow: rgba(0, 0, 0, 0.25);
      }
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html {
      -webkit-text-size-adjust: 100%;
      text-size-adjust: 100%;
    }

    body {
      margin: 0;
      min-height: 100vh;
      min-height: 100dvh;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans JP", sans-serif;
      line-height: 1.6;
      overflow-wrap: anywhere;
    }

    main {
      width: min(980px, calc(100% - 24px));
      margin: 24px auto;
      padding-bottom: max(24px, env(safe-area-inset-bottom));
    }

    h1 {
      margin: 0 0 8px;
      font-size: clamp(1.55rem, 7vw, 2.35rem);
      line-height: 1.25;
    }

    h2 {
      margin: 0 0 14px;
      font-size: 1.2rem;
    }

    .lead {
      color: var(--muted);
      margin: 0 0 18px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 16px;
      box-shadow: 0 8px 30px var(--shadow);
      margin-bottom: 16px;
    }

    label {
      display: block;
      font-weight: 700;
      margin-bottom: 8px;
    }

    textarea {
      display: block;
      width: 100%;
      min-height: 150px;
      resize: vertical;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 13px;
      font-family: inherit;
      font-size: 16px;
      line-height: 1.55;
      color: var(--text);
      background: var(--panel);
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }

    textarea:focus {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.18);
    }

    #output {
      min-height: 120px;
      font-size: 18px;
    }

    .buttons {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 10px;
      margin: 14px 0 18px;
    }

    button {
      min-height: 46px;
      border: 0;
      border-radius: 10px;
      padding: 10px 12px;
      font-family: inherit;
      font-size: 16px;
      font-weight: 700;
      cursor: pointer;
      background: var(--accent);
      color: #ffffff;
      touch-action: manipulation;
      -webkit-appearance: none;
      appearance: none;
    }

    button:active {
      transform: translateY(1px);
    }

    button:hover {
      background: var(--accent-hover);
    }

    button.secondary {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border);
    }

    .status {
      min-height: 1.5em;
      color: var(--muted);
      font-size: 0.95rem;
      margin-top: 8px;
    }

    .status.success { color: #15803d; }
    .status.error { color: #b91c1c; }

    .small {
      font-size: 0.9rem;
      color: var(--muted);
    }

    .examples {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 10px;
    }

    .example {
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
      background: var(--code);
    }

    code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      background: var(--code);
      padding: 2px 5px;
      border-radius: 5px;
      word-break: break-word;
    }

    .table-wrap {
      width: 100%;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    table {
      width: 100%;
      min-width: 460px;
      border-collapse: collapse;
    }

    th, td {
      text-align: left;
      border-bottom: 1px solid var(--border);
      padding: 10px 8px;
      vertical-align: top;
    }

    th { width: 38%; }

    .history-item {
      border-top: 1px solid var(--border);
      padding: 12px 0;
    }

    .history-item:first-child { border-top: 0; }
    .history-input { color: var(--muted); font-size: 0.92rem; white-space: pre-wrap; }
    .history-output { font-size: 1.05rem; margin-top: 4px; white-space: pre-wrap; }

    @media (max-width: 560px) {
      main {
        width: min(100% - 16px, 980px);
        margin: 12px auto;
      }

      .panel {
        padding: 14px;
        border-radius: 14px;
      }

      .buttons {
        grid-template-columns: 1fr;
      }

      button {
        width: 100%;
      }

      textarea {
        min-height: 135px;
      }
    }
  </style>
</head>
<body>
  <main>
    <h1>ж•°еӯҰиЁҳеҸ· Unicode еӨүжҸӣгғ„гғјгғ«</h1>
    <p class="lead">з°ЎеҚҳгҒӘе…ҘеҠӣиЁҳжі•гӮ’гҖҒгӮігғ”гғјеҸҜиғҪгҒӘUnicodeж•°еӯҰиЎЁзҸҫгҒёеӨүжҸӣгҒ—гҒҫгҒҷгҖӮ</p>

    <section class="panel">
      <label for="input">е…ҘеҠӣ</label>
      <textarea id="input" spellcheck="false" autocapitalize="off" autocomplete="off" autocorrect="off" placeholder="дҫӢ: lim n,inf fra n^2+1,n^3-1"></textarea>

      <div class="buttons">
        <button id="convertBtn" type="button">еӨүжҸӣгҒҷгӮӢ</button>
        <button id="copyBtn" type="button">зөҗжһңгӮ’гӮігғ”гғј</button>
        <button id="clearBtn" class="secondary" type="button">гӮҜгғӘгӮў</button>
      </div>

      <label for="output">еӨүжҸӣзөҗжһң</label>
      <textarea id="output" readonly></textarea>
      <div class="status" id="status" aria-live="polite"></div>
      <div class="small">е…ҘеҠӣгҒҷгӮӢгҒЁиҮӘеӢ•еӨүжҸӣгҒ•гӮҢгҒҫгҒҷгҖӮгӮігғ”гғјгҒ§гҒҚгҒӘгҒ„е ҙеҗҲгҒҜгҖҒзөҗжһңж¬„гҒҢйҒёжҠһгҒ•гӮҢгӮӢгҒ®гҒ§й•·жҠјгҒ—гҒ—гҒҰгӮігғ”гғјгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ</div>
    </section>

    <section class="panel">
      <h2>е…ҘеҠӣдҫӢ</h2>
      <div class="examples">
        <div class="example"><code>int 1,3 x^2+x</code><br>вҶ’ вҲ«вӮҒВі(xВІ+x) dx</div>
        <div class="example"><code>dif x^2+x</code><br>вҶ’ (d/dx)(xВІ+x)</div>
        <div class="example"><code>nth,3 x+1</code><br>вҶ’ вӮғвҲҡ(x+1)</div>
        <div class="example"><code>fra x+1,y-2</code><br>вҶ’ (x+1)/(yвҲ’2)</div>
        <div class="example"><code>lim n,inf fra 1,n^2</code><br>вҶ’ lim(nвҶ’вҲһ) 1/nВІ</div>
        <div class="example"><code>a[n+1] &lt;= b[n]</code><br>вҶ’ aвӮҷвӮҠвӮҒ вүӨ bвӮҷ</div>
      </div>
    </section>

    <section class="panel">
      <h2>дё»гҒӘеӨүжҸӣиҰҸеүҮ</h2>
      <div class="table-wrap">
        <table>
          <tr><th>е…ҘеҠӣ</th><th>еҮәеҠӣ</th></tr>
          <tr><td><code>x^2</code></td><td>xВІ</td></tr>
          <tr><td><code>a[n+1]</code></td><td>aвӮҷвӮҠвӮҒ</td></tr>
          <tr><td><code>fra x+1,y-2</code></td><td>(x+1)/(yвҲ’2)</td></tr>
          <tr><td><code>nth,2 x+1</code></td><td>вҲҡ(x+1)</td></tr>
          <tr><td><code>lim x,inf</code></td><td>lim(xвҶ’вҲһ)</td></tr>
          <tr><td><code>* / &lt;= &gt;= != &lt;=&gt; =&gt; +- inf</code></td><td>В· Г· вүӨ вүҘ вү  вҮ” вҮ’ Вұ вҲһ</td></tr>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2>еұҘжӯҙ</h2>
      <div id="history"><span class="small">гҒҫгҒ еұҘжӯҙгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</span></div>
    </section>
  </main>

  <script>
    (function () {
      'use strict';

      var superscriptMap = {
        '0':'вҒ°','1':'В№','2':'ВІ','3':'Ві','4':'вҒҙ','5':'вҒө','6':'вҒ¶','7':'вҒ·','8':'вҒё','9':'вҒ№',
        '+':'вҒә','-':'вҒ»','=':'вҒј','(':'вҒҪ',')':'вҒҫ','n':'вҒҝ','i':'вҒұ','x':'ЛЈ','y':'Кё'
      };

      var subscriptMap = {
        '0':'вӮҖ','1':'вӮҒ','2':'вӮӮ','3':'вӮғ','4':'вӮ„','5':'вӮ…','6':'вӮҶ','7':'вӮҮ','8':'вӮҲ','9':'вӮү',
        '+':'вӮҠ','-':'вӮӢ','=':'вӮҢ','(':'вӮҚ',')':'вӮҺ','a':'вӮҗ','e':'вӮ‘','h':'вӮ•','i':'бөў','j':'вұј','k':'вӮ–',
        'l':'вӮ—','m':'вӮҳ','n':'вӮҷ','o':'вӮ’','p':'вӮҡ','r':'бөЈ','s':'вӮӣ','t':'вӮң','u':'бөӨ','v':'бөҘ','x':'вӮ“'
      };

      var inputEl = document.getElementById('input');
      var outputEl = document.getElementById('output');
      var statusEl = document.getElementById('status');
      var historyEl = document.getElementById('history');
      var convertBtn = document.getElementById('convertBtn');
      var copyBtn = document.getElementById('copyBtn');
      var clearBtn = document.getElementById('clearBtn');
      var history = [];
      var slashMarker = 'вҹҰFRACTION_SLASHвҹ§';

      function mapCharacters(text, map) {
        var result = '';
        var i;
        for (i = 0; i < text.length; i += 1) {
          result += Object.prototype.hasOwnProperty.call(map, text.charAt(i)) ? map[text.charAt(i)] : text.charAt(i);
        }
        return result;
      }

      function toSuperscript(text) {
        return mapCharacters(text, superscriptMap);
      }

      function toSubscript(text) {
        return mapCharacters(text, subscriptMap);
      }

      function normalizeMinus(text) {
        return String(text).replace(/-/g, 'вҲ’');
      }

      function isCompound(expr) {
        var trimmed = expr.replace(/^\s+|\s+$/g, '');
        if (/^вҲ’?[A-Za-zО‘-ПүОұ-Пү0-9]+[вҒ°В№ВІВівҒҙвҒөвҒ¶вҒ·вҒёвҒ№вҒәвҒ»вҒҝвҒұЛЈКёвӮҖвӮҒвӮӮвӮғвӮ„вӮ…вӮҶвӮҮвӮҲвӮүвӮҠвӮӢвӮҗвӮ‘вӮ•бөўвұјвӮ–вӮ—вӮҳвӮҷвӮ’вӮҡбөЈвӮӣвӮңбөӨбөҘвӮ“]*$/.test(trimmed)) {
          return false;
        }
        return /[+вҲ’В·Г·/]/.test(trimmed.substring(1)) || /^вҲ’/.test(trimmed) || /\s/.test(trimmed);
      }

      function wrapIfNeeded(expr) {
        var trimmed = expr.replace(/^\s+|\s+$/g, '');
        return isCompound(trimmed) ? '(' + trimmed + ')' : trimmed;
      }

      function findTopLevelComma(text) {
        var round = 0;
        var square = 0;
        var i;
        var ch;
        for (i = 0; i < text.length; i += 1) {
          ch = text.charAt(i);
          if (ch === '(') round += 1;
          else if (ch === ')') round = Math.max(0, round - 1);
          else if (ch === '[') square += 1;
          else if (ch === ']') square = Math.max(0, square - 1);
          else if (ch === ',' && round === 0 && square === 0) return i;
        }
        return -1;
      }

      function convertPowers(text) {
        return text.replace(/\^\(([^()]+)\)|\^(-?[0-9]+|[A-Za-z])/g, function (match, grouped, simple) {
          return toSuperscript(grouped !== undefined ? '(' + grouped + ')' : simple);
        });
      }

      function convertSubscripts(text) {
        return text.replace(/([A-Za-zО‘-ПүОұ-Пү])\[([^\]]+)\]/g, function (match, base, sub) {
          return base + toSubscript(sub);
        });
      }

      function convertFractions(text) {
        var current = text;
        var safety = 0;
        var changed;

        do {
          changed = false;
          current = current.replace(/\bfra\s+([^\n]+)/, function (match, tail) {
            var comma = findTopLevelComma(tail);
            var numerator;
            var denominator;
            var convertedNum;
            var convertedDen;

            if (comma < 0) return match;
            numerator = tail.substring(0, comma).replace(/^\s+|\s+$/g, '');
            denominator = tail.substring(comma + 1).replace(/^\s+|\s+$/g, '');
            if (!numerator || !denominator) return match;

            convertedNum = convertInline(numerator, false);
            convertedDen = convertInline(denominator, false);
            changed = true;
            return wrapIfNeeded(convertedNum) + slashMarker + wrapIfNeeded(convertedDen);
          });
          safety += 1;
        } while (changed && /\bfra\s+/.test(current) && safety < 30);

        return current;
      }

      function convertRoots(text) {
        return text.replace(/\bnth\s*,\s*([^\s]+)\s+([^\n]+)/g, function (match, degree, body) {
          var convertedBody = convertInline(body.replace(/^\s+|\s+$/g, ''), false);
          var root = degree === '2' ? 'вҲҡ' : toSubscript(degree) + 'вҲҡ';
          return root + '(' + convertedBody + ')';
        });
      }

      function convertLimits(text) {
        return text.replace(/\blim\s+([^,\s]+)\s*,\s*([^\s]+)/g, function (match, variable, target) {
          var convertedTarget = target === 'inf' ? 'вҲһ' : normalizeMinus(target);
          return 'lim(' + variable + 'вҶ’' + convertedTarget + ')';
        });
      }

      function convertIntegrals(text) {
        return text.replace(/\bint(?:\s+([^,\s]+)\s*,\s*([^\s]+))?\s+([^\n]+)/g, function (match, lower, upper, body) {
          var convertedBody = convertInline(body.replace(/^\s+|\s+$/g, ''), false);
          var lo;
          var up;
          if (lower !== undefined) {
            lo = lower === 'inf' ? 'вҲһ' : toSubscript(normalizeMinus(lower));
            up = upper === 'inf' ? 'вҲһ' : toSuperscript(normalizeMinus(upper));
            return 'вҲ«' + lo + up + '(' + convertedBody + ') dx';
          }
          return 'вҲ«(' + convertedBody + ') dx';
        });
      }

      function convertDifferentials(text) {
        return text.replace(/\bdif\s+([^\n]+)/g, function (match, body) {
          return '(d' + slashMarker + 'dx)(' + convertInline(body.replace(/^\s+|\s+$/g, ''), false) + ')';
        });
      }

      function convertSymbols(text, convertOrdinarySlash) {
        var out = text;
        out = out.replace(/<=>/g, 'вҮ”');
        out = out.replace(/=>/g, 'вҮ’');
        out = out.replace(/<=/g, 'вүӨ');
        out = out.replace(/>=/g, 'вүҘ');
        out = out.replace(/!=/g, 'вү ');
        out = out.replace(/\+\-/g, 'Вұ');
        out = out.replace(/\*/g, 'В·');
        out = out.replace(/\binf\b/g, 'вҲһ');
        out = out.replace(/-/g, 'вҲ’');
        if (convertOrdinarySlash) out = out.replace(/\//g, 'Г·');
        return out;
      }

      function convertInline(text, convertOrdinarySlash) {
        var out = text;
        out = convertFractions(out);
        out = convertRoots(out);
        out = convertLimits(out);
        out = convertSubscripts(out);
        out = convertPowers(out);
        out = convertSymbols(out, convertOrdinarySlash !== false);
        out = out.split(slashMarker).join('/');
        return out;
      }

      function convertAll(text) {
        var out = String(text).replace(/^\s+|\s+$/g, '');
        if (!out) return '';
        out = convertFractions(out);
        out = convertRoots(out);
        out = convertLimits(out);
        out = convertIntegrals(out);
        out = convertDifferentials(out);
        out = convertSubscripts(out);
        out = convertPowers(out);
        out = convertSymbols(out, true);
        out = out.split(slashMarker).join('/');
        return out;
      }

      function setStatus(message, type) {
        statusEl.className = 'status' + (type ? ' ' + type : '');
        statusEl.textContent = message;
      }

      function updateOutput(saveHistory) {
        var input = inputEl.value;
        var output = convertAll(input);
        outputEl.value = output;
        setStatus(output ? 'еӨүжҸӣжёҲгҒҝ' : '', '');
        if (saveHistory && input.replace(/^\s+|\s+$/g, '') && output) {
          addHistory(input.replace(/^\s+|\s+$/g, ''), output);
        }
      }

      function escapeHtml(text) {
        return String(text).replace(/[&<>"']/g, function (ch) {
          var map = {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'};
          return map[ch];
        });
      }

      function renderHistory() {
        var html = '';
        var i;
        if (!history.length) {
          historyEl.innerHTML = '<span class="small">гҒҫгҒ еұҘжӯҙгҒҜгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ</span>';
          return;
        }
        for (i = 0; i < history.length; i += 1) {
          html += '<div class="history-item">' +
            '<div class="history-input">' + escapeHtml(history[i].input) + '</div>' +
            '<div class="history-output">' + escapeHtml(history[i].output) + '</div>' +
            '</div>';
        }
        historyEl.innerHTML = html;
      }

      function saveHistory() {
        try {
          window.localStorage.setItem('mathUnicodeConverterHistory', JSON.stringify(history));
        } catch (ignore) {}
      }

      function loadHistory() {
        try {
          var saved = window.localStorage.getItem('mathUnicodeConverterHistory');
          var parsed;
          if (saved) {
            parsed = JSON.parse(saved);
            if (Object.prototype.toString.call(parsed) === '[object Array]') {
              history = parsed.slice(0, 10);
            }
          }
        } catch (ignore) {
          history = [];
        }
        renderHistory();
      }

      function addHistory(input, output) {
        if (!input || !output) return;
        if (history.length && history[0].input === input && history[0].output === output) return;
        history.unshift({input: input, output: output});
        history = history.slice(0, 10);
        renderHistory();
        saveHistory();
      }

      function selectOutputForManualCopy() {
        outputEl.removeAttribute('readonly');
        outputEl.focus();
        outputEl.select();
        try {
          outputEl.setSelectionRange(0, outputEl.value.length);
        } catch (ignore) {}
        outputEl.setAttribute('readonly', 'readonly');
      }

      function legacyCopy(text) {
        var helper = document.createElement('textarea');
        var successful = false;
        helper.value = text;
        helper.setAttribute('readonly', 'readonly');
        helper.style.position = 'fixed';
        helper.style.left = '0';
        helper.style.top = '0';
        helper.style.width = '1px';
        helper.style.height = '1px';
        helper.style.padding = '0';
        helper.style.border = '0';
        helper.style.opacity = '0.01';
        helper.style.fontSize = '16px';
        document.body.appendChild(helper);
        helper.focus();
        helper.select();
        try {
          helper.setSelectionRange(0, helper.value.length);
          successful = document.execCommand('copy');
        } catch (ignore) {
          successful = false;
        }
        document.body.removeChild(helper);
        return successful;
      }

      function copyResult() {
        var text = outputEl.value;
        var input = inputEl.value.replace(/^\s+|\s+$/g, '');

        if (!text) {
          setStatus('гӮігғ”гғјгҒҷгӮӢзөҗжһңгҒҢгҒӮгӮҠгҒҫгҒӣгӮ“гҖӮ', 'error');
          return;
        }

        function copied() {
          setStatus('зөҗжһңгӮ’гӮігғ”гғјгҒ—гҒҫгҒ—гҒҹгҖӮ', 'success');
          addHistory(input, text);
        }

        function fallback() {
          if (legacyCopy(text)) {
            copied();
          } else {
            selectOutputForManualCopy();
            setStatus('зөҗжһңгӮ’йҒёжҠһгҒ—гҒҫгҒ—гҒҹгҖӮй•·жҠјгҒ—гҒ—гҒҰгӮігғ”гғјгҒ—гҒҰгҒҸгҒ гҒ•гҒ„гҖӮ', 'error');
          }
        }

        if (window.isSecureContext && navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(text).then(copied, fallback);
        } else {
          fallback();
        }
      }

      function clearAll() {
        inputEl.value = '';
        outputEl.value = '';
        setStatus('', '');
        inputEl.focus();
      }

      inputEl.addEventListener('input', function () { updateOutput(false); }, false);
      inputEl.addEventListener('keyup', function () { updateOutput(false); }, false);
      inputEl.addEventListener('change', function () { updateOutput(false); }, false);
      convertBtn.addEventListener('click', function () { updateOutput(true); }, false);
      copyBtn.addEventListener('click', copyResult, false);
      clearBtn.addEventListener('click', clearAll, false);

      document.addEventListener('keydown', function (event) {
        var key = event.key || event.keyCode;
        if ((event.ctrlKey || event.metaKey) && (key === 'Enter' || key === 13)) {
          if (event.preventDefault) event.preventDefault();
          copyResult();
        }
      }, false);

      loadHistory();
      inputEl.value = 'lim n,inf fra n^2+1,n^3-1';
      updateOutput(false);
    }());
  </script>
